generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionCompletionSource {
  manual
  derived_all_activities
}

enum PlanTweakScope {
  week
  whole_plan
}

enum PlanTweakStatus {
  pending
  accepted
  rejected
  failed
}

enum PlanChatRole {
  user
  assistant
}

enum PlanGenerationJobStatus {
  queued
  running
  succeeded
  failed
  canceled
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  passwordHash           String
  name                   String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  emailVerified          DateTime?
  image                  String?
  accounts               Account[]
  sessions               Session[]
  questionnaireResponses QuestionnaireResponse[]
  trainingPlans          TrainingPlan[]
  activityCompletions    ActivityCompletion[]
  sessionCompletions     SessionCompletion[]
  planTweakRequests      PlanTweakRequest[]
  planChatThreads        PlanChatThread[]
  sessionNotes           SessionNote[]
  planGenerationJobs     PlanGenerationJob[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model QuestionnaireResponse {
  id             String       @id @default(cuid())
  userId         String
  trainingPlanId String?
  data           Json
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingPlan TrainingPlan? @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  planGenerationJobs PlanGenerationJob[]

  @@index([userId, trainingPlanId, createdAt])
}

model TrainingPlan {
  id                   String                @id @default(cuid())
  userId               String
  name                 String
  goal                 String?
  currentPlanVersionId String?               @unique
  deletedAt            DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  versions             TrainingPlanVersion[] @relation("PlanVersions")
  currentPlanVersion   TrainingPlanVersion?  @relation("CurrentPlanVersion", fields: [currentPlanVersionId], references: [id], onDelete: SetNull)
  questionnaireResponses QuestionnaireResponse[]
  activityCompletions  ActivityCompletion[]
  sessionCompletions   SessionCompletion[]
  planTweakRequests    PlanTweakRequest[]
  planChatThreads      PlanChatThread[]
  sessionNotes         SessionNote[]
  generationJobs       PlanGenerationJob[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@index([userId, deletedAt, updatedAt])
}

model TrainingPlanVersion {
  id             String       @id @default(cuid())
  trainingPlanId String
  versionNumber  Int
  planJson       Json
  createdAt      DateTime     @default(now())
  trainingPlan   TrainingPlan @relation("PlanVersions", fields: [trainingPlanId], references: [id], onDelete: Cascade)
  currentForPlan TrainingPlan? @relation("CurrentPlanVersion")
  activityCompletions ActivityCompletion[]
  sessionCompletions SessionCompletion[]
  sourceTweakRequests PlanTweakRequest[] @relation("SourcePlanVersion")
  resultTweakRequests PlanTweakRequest[] @relation("ResultPlanVersion")
  planChatThreads PlanChatThread[]
  sessionNotes SessionNote[]
  generatedByJobs PlanGenerationJob[] @relation("GeneratedPlanVersion")

  @@unique([trainingPlanId, versionNumber])
  @@index([trainingPlanId, createdAt])
}

model PlanGenerationJob {
  id                    String                  @id @default(cuid())
  userId                String
  trainingPlanId        String
  questionnaireResponseId String
  idempotencyKey        String                  @unique
  status                PlanGenerationJobStatus
  retryCount            Int?
  resultPlanVersionId   String?
  errorCode             String?
  errorMessage          String?
  errorDetails          Json?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  startedAt             DateTime?
  finishedAt            DateTime?

  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingPlan          TrainingPlan            @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  questionnaireResponse QuestionnaireResponse   @relation(fields: [questionnaireResponseId], references: [id], onDelete: Cascade)
  resultPlanVersion     TrainingPlanVersion?    @relation("GeneratedPlanVersion", fields: [resultPlanVersionId], references: [id], onDelete: SetNull)

  @@index([userId, trainingPlanId, createdAt])
  @@index([trainingPlanId, status, createdAt])
}

model ActivityCompletion {
  id             String              @id @default(cuid())
  userId         String
  trainingPlanId String
  planVersionId  String
  weekNumber     Int
  sessionNumber  Int
  activityId     String
  completedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingPlan   TrainingPlan        @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  planVersion    TrainingPlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)

  @@unique([userId, planVersionId, weekNumber, sessionNumber, activityId])
  @@index([trainingPlanId, planVersionId])
}

model SessionCompletion {
  id               String                  @id @default(cuid())
  userId           String
  trainingPlanId   String
  planVersionId    String
  weekNumber       Int
  sessionNumber    Int
  completedAt      DateTime?
  completionSource SessionCompletionSource
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingPlan     TrainingPlan            @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  planVersion      TrainingPlanVersion     @relation(fields: [planVersionId], references: [id], onDelete: Cascade)

  @@unique([userId, planVersionId, weekNumber, sessionNumber])
  @@index([trainingPlanId, planVersionId])
}

model PlanTweakRequest {
  id                  String              @id @default(cuid())
  userId              String
  trainingPlanId      String
  sourcePlanVersionId String
  resultPlanVersionId String?
  scope               PlanTweakScope
  targetWeekNumber    Int?
  requestText         String
  llmSummaryText      String?
  status              PlanTweakStatus
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingPlan        TrainingPlan        @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  sourcePlanVersion   TrainingPlanVersion @relation("SourcePlanVersion", fields: [sourcePlanVersionId], references: [id], onDelete: Cascade)
  resultPlanVersion   TrainingPlanVersion? @relation("ResultPlanVersion", fields: [resultPlanVersionId], references: [id], onDelete: SetNull)
  planChatMessages    PlanChatMessage[]

  @@index([trainingPlanId, createdAt])
  @@index([trainingPlanId, status, createdAt])
}

model PlanChatThread {
  id             String              @id @default(cuid())
  userId         String
  trainingPlanId String
  planVersionId  String
  title          String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingPlan   TrainingPlan        @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  planVersion    TrainingPlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)
  messages       PlanChatMessage[]

  @@index([trainingPlanId, updatedAt])
}

model PlanChatMessage {
  id                   String           @id @default(cuid())
  threadId             String
  role                 PlanChatRole
  content              String
  sourceTweakRequestId String?
  createdAt            DateTime         @default(now())
  thread               PlanChatThread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sourceTweakRequest   PlanTweakRequest? @relation(fields: [sourceTweakRequestId], references: [id], onDelete: SetNull)

  @@index([threadId, createdAt])
}

model SessionNote {
  id             String              @id @default(cuid())
  userId         String
  trainingPlanId String
  planVersionId  String
  weekNumber     Int
  sessionNumber  Int
  noteText       String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingPlan   TrainingPlan        @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  planVersion    TrainingPlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)

  @@unique([userId, planVersionId, weekNumber, sessionNumber])
  @@index([trainingPlanId, planVersionId])
}
