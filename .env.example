DATABASE_URL="postgresql://postgres:postgres@localhost:5432/climbing_coach?schema=public"
NEXTAUTH_URL="https://coachedclimbing.com"
NEXTAUTH_SECRET="replace-with-at-least-16-chars"

# LLM provider selection: "openai" (default) or "gemini"
LLM_PROVIDER="openai"

# OpenAI (required when LLM_PROVIDER="openai")
OPENAI_API_KEY="replace-me"
OPENAI_MODEL_PRIMARY="gpt-5-mini"

# Gemini (required when LLM_PROVIDER="gemini")
# GEMINI_API_KEY="replace-me"
# GEMINI_MODEL_PRIMARY="gemini-2.5-pro"
